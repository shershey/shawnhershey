---
const { title } = Astro.props;
---
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title ? `${title} | Shawn Hershey` : 'Shawn Hershey'}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700&family=Source+Sans+3:wght@400;600&display=swap" rel="stylesheet" />
    <style>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

      body {
        background: #f7f2ea;
        color: #1e1a16;
        font-family: 'Source Sans 3', Georgia, sans-serif;
        font-size: 1.05rem;
        line-height: 1.6;
        min-height: 100vh;
      }

      header {
        background: #1e1a16;
        color: #f7f2ea;
        padding: 1.25rem 1.5rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 0.75rem;
      }

      header a.site-name {
        font-family: 'Playfair Display', Georgia, serif;
        font-size: 1.5rem;
        color: #e8c97e;
        text-decoration: none;
        letter-spacing: 0.02em;
      }

      nav {
        display: flex;
        gap: 1.5rem;
      }

      nav a {
        color: #f7f2ea;
        text-decoration: none;
        font-size: 0.95rem;
        letter-spacing: 0.04em;
        text-transform: uppercase;
        opacity: 0.85;
        transition: opacity 0.15s;
      }

      nav a:hover { opacity: 1; }

      main {
        max-width: 48rem;
        margin: 0 auto;
        padding: 2.5rem 1.5rem 4rem;
      }

      h1 {
        font-family: 'Playfair Display', Georgia, serif;
        font-size: 2.25rem;
        color: #1e1a16;
        margin-bottom: 1.5rem;
        line-height: 1.2;
      }

      h2 {
        font-family: 'Playfair Display', Georgia, serif;
        font-size: 1.35rem;
        color: #5a3e1b;
        margin: 2rem 0 0.75rem;
        padding-bottom: 0.35rem;
        border-bottom: 1px solid #d4c4a0;
      }

      p { margin-top: 0.75rem; }

      a {
        color: #7a4f1e;
        text-decoration: underline;
        text-underline-offset: 2px;
      }

      a:hover { color: #5a3e1b; }

      blockquote {
        border-left: 3px solid #d4c4a0;
        padding-left: 1rem;
        margin: 1.25rem 0;
        color: #5a4a36;
        font-style: italic;
      }

      footer {
        text-align: center;
        padding: 2rem 1rem;
        font-size: 0.85rem;
        color: #8a7a66;
        border-top: 1px solid #d4c4a0;
      }

      footer .social {
        display: flex;
        justify-content: center;
        gap: 1.1rem;
        margin-bottom: 0.65rem;
      }

      footer .social a {
        color: #8a7a66;
        display: inline-flex;
        transition: color 0.15s;
      }

      footer .social a:hover { color: #e8c97e; }

      footer .social svg { width: 22px; height: 22px; fill: currentColor; }
    </style>
  </head>
  <body>
    <header>
      <a href="/" class="site-name">Shawn Hershey</a>
      <nav>
        <a href="/">Home</a>
        <a href="/bio">Bios &amp; Photos</a>
        <a href="/videos">Videos</a>
        <a href="/where">Where's Shawn</a>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer>
      <div class="social">
        <a href="https://www.instagram.com/shawn.hershey/" target="_blank" rel="noopener" aria-label="Instagram">
          <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
        </a>
        <a href="https://www.facebook.com/shawn.hershey" target="_blank" rel="noopener" aria-label="Facebook">
          <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
        </a>
      </div>
      <div>shawnhershey.com</div>
    </footer>
  </body>
</html>
