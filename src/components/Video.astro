---
const { video } = Astro.props;

// Work out how to show a video from its link.
// YouTube links become embedded players; anything else becomes a link;
// an empty link shows as "coming soon".
function resolve(v) {
  const url = (v.url || '').trim();
  if (!url) return { ...v, kind: 'none' };

  const full = /^https?:\/\//i.test(url) ? url : `https://${url}`;
  const yt = full.match(/(?:youtu\.be\/|youtube\.com\/(?:watch\?v=|embed\/|shorts\/))([\w-]+)/i);
  if (yt) {
    const t = full.match(/[?&](?:t|start)=(\d+)/);
    const src = `https://www.youtube.com/embed/${yt[1]}${t ? `?start=${t[1]}` : ''}`;
    return { ...v, kind: 'youtube', src };
  }
  const ig = full.match(/instagram\.com\/(reel|p|tv)\/([\w-]+)/i);
  if (ig) {
    const src = `https://www.instagram.com/${ig[1]}/${ig[2]}/embed`;
    return { ...v, kind: 'instagram', src };
  }
  return { ...v, kind: 'link', href: full };
}

const v = resolve(video);
---
<div class="video-item">
  {v.kind === 'youtube' && (
    <div class="embed">
      <iframe
        src={v.src}
        title={v.title}
        loading="lazy"
        frameborder="0"
        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
        allowfullscreen
      ></iframe>
    </div>
  )}
  {v.kind === 'instagram' && (
    <div class="ig-embed">
      <iframe
        src={v.src}
        title={v.title}
        loading="lazy"
        frameborder="0"
        scrolling="no"
        allowtransparency="true"
        allowfullscreen
      ></iframe>
    </div>
  )}
  <p class="caption">
    {v.kind === 'link'
      ? <a href={v.href} target="_blank" rel="noopener">{v.title} →</a>
      : <span>{v.title}</span>}
    {v.kind === 'none' && <span class="soon"> {v.note ? `(${v.note})` : '(coming soon)'}</span>}
  </p>
</div>

<style>
  .embed {
    position: relative;
    width: 100%;
    padding-top: 56.25%;
    background: #1e1a16;
    border-radius: 4px;
    overflow: hidden;
  }
  .embed iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: 0;
  }
  .ig-embed {
    max-width: 340px;
  }
  .ig-embed iframe {
    width: 100%;
    height: 540px;
    border: 0;
    background: #fff;
    border-radius: 4px;
  }
  .caption {
    margin-top: 0.5rem;
    font-size: 0.95rem;
  }
  .caption .soon {
    color: #8a7a66;
    font-style: italic;
  }
</style>
