---
const { video } = Astro.props;

// Work out how to show a video from its link.
// YouTube links become embedded players; anything else becomes a link;
// an empty link shows as "coming soon".
function resolve(v) {
  const url = (v.url || '').trim();
  if (!url) return { ...v, kind: 'none' };

  const full = /^https?:\/\//i.test(url) ? url : `https://${url}`;
  const yt = full.match(/(?:youtu\.be\/|youtube\.com\/(?:watch\?v=|embed\/|shorts\/))([\w-]+)/i);
  if (yt) {
    const t = full.match(/[?&](?:t|start)=(\d+)/);
    const src = `https://www.youtube.com/embed/${yt[1]}${t ? `?start=${t[1]}` : ''}`;
    return { ...v, kind: 'youtube', src };
  }
  const ig = full.match(/instagram\.com\/(reel|p|tv)\/([\w-]+)/i);
  if (ig) {
    const permalink = `https://www.instagram.com/${ig[1]}/${ig[2]}/`;
    return { ...v, kind: 'instagram', permalink };
  }
  return { ...v, kind: 'link', href: full };
}

const v = resolve(video);
---
<div class="video-item">
  {v.kind === 'youtube' && (
    <div class="embed">
      <iframe
        src={v.src}
        title={v.title}
        loading="lazy"
        frameborder="0"
        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
        allowfullscreen
      ></iframe>
    </div>
  )}
  {v.kind === 'instagram' && (
    <blockquote
      class="instagram-media"
      data-instgrm-permalink={v.permalink}
      data-instgrm-version="14"
      style="background:#FFF; border:0; border-radius:3px; box-shadow:0 0 1px 0 rgba(0,0,0,0.5),0 1px 10px 0 rgba(0,0,0,0.15); margin:0; max-width:540px; min-width:326px; padding:0; width:100%;"
    ></blockquote>
  )}
  <p class="caption">
    {v.kind === 'link'
      ? <a href={v.href} target="_blank" rel="noopener">{v.title} →</a>
      : <span>{v.title}</span>}
    {v.kind === 'none' && <span class="soon"> {v.note ? `(${v.note})` : '(coming soon)'}</span>}
  </p>
</div>

<style>
  .embed {
    position: relative;
    width: 100%;
    padding-top: 56.25%;
    background: #1e1a16;
    border-radius: 4px;
    overflow: hidden;
  }
  .embed iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: 0;
  }
  .instagram-media {
    margin: 0 auto !important;
  }
  .caption {
    margin-top: 0.5rem;
    font-size: 0.95rem;
  }
  .caption .soon {
    color: #8a7a66;
    font-style: italic;
  }
</style>
