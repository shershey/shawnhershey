---
import Layout from '../layouts/Layout.astro';
import Video from '../components/Video.astro';
import categories from '../data/videos.js';

const sections = Object.entries(categories);
const hasInstagram = sections.some(([, vids]) =>
  vids.some((v) => /instagram\.com\/(reel|p|tv)\//i.test(v.url || ''))
);
---
<Layout title="Videos">
  <h1>Videos</h1>
  <p>A selection of performances and competitions, by style.</p>

  {sections.map(([name, videos]) => (
    <section class="category">
      <h2>{name}</h2>

      {videos.length === 0 ? (
        <p class="soon">Videos coming soon.</p>
      ) : (
        <>
          <div class="featured">
            <Video video={videos[0]} />
          </div>

          {videos.length > 1 && (
            <details>
              <summary>Show {videos.length - 1} more</summary>
              <div class="video-grid">
                {videos.slice(1).map((v) => <Video video={v} />)}
              </div>
            </details>
          )}
        </>
      )}
    </section>
  ))}

  {hasInstagram && <script async src="https://www.instagram.com/embed.js" is:inline></script>}

  <style>
    .category {
      margin-bottom: 2.5rem;
    }
    .featured {
      max-width: 32rem;
    }
    .video-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
      gap: 1.5rem;
      margin-top: 1.25rem;
    }
    details {
      margin-top: 1rem;
    }
    summary {
      cursor: pointer;
      color: #7a4f1e;
      font-size: 0.95rem;
      letter-spacing: 0.02em;
      width: fit-content;
    }
    summary:hover {
      color: #5a3e1b;
    }
    .soon {
      color: #8a7a66;
      font-style: italic;
    }
  </style>
</Layout>
